<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crystal Lattice Constructor</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <style>
        body { margin: 0; background-color: #f3f4f6; font-family: sans-serif; }
        #canvas-container { width: 100%; height: 55vh; position: relative; border-radius: 1rem; overflow: hidden; }
        @media (min-width: 768px) {
            #canvas-container { height: 65vh; }
        }
        canvas { display: block; }
        .info-card { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(4px); }
        input[type="range"] { accent-color: #2563eb; }
        .toggle-checkbox:checked { right: 0; border-color: #68D391; }
        .toggle-checkbox:checked + .toggle-label { background-color: #68D391; }
        
        /* Interactive Card Styles */
        .interactive-card {
            transition: all 0.2s ease-in-out;
            cursor: pointer;
        }
        .interactive-card:hover {
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }
        .interactive-card:active {
            transform: translateY(0) scale(0.98);
        }
    </style>
</head>
<body class="bg-gray-100 min-h-screen flex flex-col p-2 md:p-6">

    <div class="max-w-5xl mx-auto w-full bg-white rounded-2xl shadow-xl overflow-hidden flex flex-col">

        <!-- 3D Viewport Area -->
        <div id="canvas-container" class="bg-slate-50 relative">
            <div class="absolute top-4 left-4 z-10 flex gap-2">
                <div class="bg-white/80 px-3 py-1 rounded-full text-[10px] font-bold text-gray-600 shadow-sm flex items-center gap-1 uppercase tracking-tighter">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                    Orbit / Zoom
                </div>
            </div>
            
            <!-- Statistics Overlay with Clickable Buttons -->
            <div class="absolute bottom-4 left-4 right-4 z-10 grid grid-cols-4 gap-2 md:gap-4">
                
                <!-- TYPE CARD (Contains invisible native select dropdown) -->
                <div class="relative interactive-card info-card p-2 md:p-3 rounded-xl shadow-md border-2 border-blue-200 bg-white/95 text-center flex flex-col justify-center items-center">
                    <select id="lattice-select" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-20">
                        <option value="SC">Simple Cubic (SC)</option>
                        <option value="BCC" selected>Body-Centered (BCC)</option>
                        <option value="FCC">Face-Centered (FCC)</option>
                    </select>
                    
                    <div class="z-10 flex flex-col items-center justify-center w-full pointer-events-none">
                        <span class="text-[8px] md:text-[9px] uppercase tracking-wider text-blue-500 block font-bold mb-0.5 flex items-center justify-center gap-0.5">
                            Type 
                            <svg class="w-2 h-2 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path></svg>
                        </span>
                        <span id="stat-type" class="text-sm md:text-base font-bold text-blue-700">BCC</span>
                    </div>
                </div>

                <!-- CLICKABLE BASIS VECTORS CARD -->
                <div id="vector-card" class="interactive-card info-card p-2 md:p-3 rounded-xl shadow-md border-2 border-slate-300 bg-slate-100 text-center flex flex-col justify-center items-center">
                    <span class="text-[8px] md:text-[9px] uppercase tracking-wider text-slate-500 block font-bold mb-0.5">Vectors (Tap)</span>
                    <span id="stat-basis" class="text-sm md:text-base font-bold text-slate-700">3</span>
                </div>

                <!-- CLICKABLE COORD. NUM CARD -->
                <div id="cn-card" class="interactive-card info-card p-2 md:p-3 rounded-xl shadow-md border-2 border-amber-300 bg-amber-50/95 text-center flex flex-col justify-center items-center">
                    <span class="text-[8px] md:text-[9px] uppercase tracking-wider text-amber-600 block font-bold mb-0.5">Coord. Num (Tap)</span>
                    <span id="stat-cn" class="text-sm md:text-base font-bold text-amber-600">?</span>
                </div>

                <div class="info-card p-2 md:p-3 rounded-xl shadow-md border border-gray-100 text-center flex flex-col justify-center items-center">
                    <span class="text-[8px] md:text-[9px] uppercase tracking-wider text-gray-400 block font-bold mb-0.5">Visible Atoms</span>
                    <span id="stat-atoms" class="text-sm md:text-base font-bold text-gray-800">343</span>
                </div>
            </div>
        </div>

        <!-- Controls (Simplified Layout) -->
        <div class="p-4 md:p-5 space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-center">
                
                <!-- Extent Slider -->
                <div class="space-y-2">
                    <div class="flex justify-between">
                        <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide">Extent (Cubes)</label>
                        <span id="extent-value" class="text-xs font-bold text-blue-600 bg-blue-50 px-2 rounded">2</span>
                    </div>
                    <!-- Max extent capped at 4 for performance while still giving a massive visual crystal -->
                    <input type="range" id="extent-slider" min="1" max="4" value="2" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer">
                </div>

                <!-- Atom Size Slider -->
                <div class="space-y-2">
                    <div class="flex justify-between">
                        <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide">Atom Radius</label>
                        <span id="size-value" class="text-xs font-bold text-blue-600 bg-blue-50 px-2 rounded">0.12</span>
                    </div>
                    <input type="range" id="size-slider" min="0.05" max="0.5" step="0.01" value="0.12" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer">
                </div>

                <!-- Toggles -->
                <div class="flex flex-col justify-center items-start md:items-end w-full gap-3">
                    <label class="flex items-center cursor-pointer">
                        <div class="relative">
                            <input type="checkbox" id="show-axes" class="sr-only" checked>
                            <div class="block bg-gray-200 w-10 h-6 rounded-full transition-colors toggle-bg"></div>
                            <div class="dot absolute left-1 top-1 bg-white w-4 h-4 rounded-full transition-transform transform translate-x-0 toggle-dot"></div>
                        </div>
                        <div class="ml-3 text-xs font-bold text-gray-600 uppercase tracking-wide">Show XYZ Axes</div>
                    </label>

                    <label class="flex items-center cursor-pointer">
                        <div class="relative">
                            <input type="checkbox" id="show-cells" class="sr-only">
                            <div class="block bg-gray-200 w-10 h-6 rounded-full transition-colors toggle-bg"></div>
                            <div class="dot absolute left-1 top-1 bg-white w-4 h-4 rounded-full transition-transform transform translate-x-0 toggle-dot"></div>
                        </div>
                        <div class="ml-3 text-xs font-bold text-gray-600 uppercase tracking-wide">Show Unit Cells</div>
                    </label>
                </div>
            </div>

            <!-- Vector Display & Legend -->
            <div class="p-3 bg-slate-900 rounded-xl text-blue-300 font-mono text-[10px] md:text-xs overflow-x-auto border border-slate-700 shadow-inner mt-4 flex justify-between items-center">
                <div id="vector-formula" class="grid grid-cols-3 gap-2 flex-grow">
                    <!-- Formulas will be injected here -->
                </div>
                <!-- Mini Legend -->
                <div class="ml-4 pl-4 border-l border-slate-600 flex flex-col justify-center gap-1 text-[9px] min-w-[75px]">
                    <div class="flex items-center gap-1.5"><div class="w-2 h-2 rounded-full bg-red-500"></div> Origin</div>
                    <div class="flex items-center gap-1.5"><div class="w-2 h-2 rounded-full bg-green-500"></div> Primary Cell</div>
                    <div class="flex items-center gap-1.5"><div class="w-2 h-2 rounded-full bg-amber-500"></div> Neighbors</div>
                </div>
            </div>
        </div>
    </div>

    <style>
        input:checked ~ .toggle-bg { background-color: #3b82f6; }
        input:checked ~ .dot { transform: translateX(100%); }
    </style>

    <script>
        let scene, camera, renderer, controls;
        let atomsGroup, vectorsGroup, gridGroup, axesGroup, neighborsGroup;
        let isShowingNeighbors = false; 
        let isShowingVectors = true; // New state to track Vector visibility
        const a = 2.0; 

        const LATTICES = {
            SC: {
                name: "Simple Cubic (SC)",
                getVectors: (a) => [new THREE.Vector3(a, 0, 0), new THREE.Vector3(0, a, 0), new THREE.Vector3(0, 0, a)],
                formula: ["a₁ = a x̂", "a₂ = a ŷ", "a₃ = a ẑ"],
                cn: 6,
                nnDistance: a 
            },
            BCC: {
                name: "Body-Centered (BCC)",
                getVectors: (a) => [
                    new THREE.Vector3(-a/2, a/2, a/2),
                    new THREE.Vector3(a/2, -a/2, a/2),
                    new THREE.Vector3(a/2, a/2, -a/2)
                ],
                formula: ["a₁ = a/2 (-x̂+ŷ+ẑ)", "a₂ = a/2 (x̂-ŷ+ẑ)", "a₃ = a/2 (x̂+ŷ-ẑ)"],
                cn: 8,
                nnDistance: a * Math.sqrt(3) / 2 
            },
            FCC: {
                name: "Face-Centered (FCC)",
                getVectors: (a) => [
                    new THREE.Vector3(0, a/2, a/2),
                    new THREE.Vector3(a/2, 0, a/2),
                    new THREE.Vector3(a/2, a/2, 0)
                ],
                formula: ["a₁ = a/2 (ŷ+ẑ)", "a₂ = a/2 (ẑ+x̂)", "a₃ = a/2 (x̂+ŷ)"],
                cn: 12,
                nnDistance: a * Math.sqrt(2) / 2 
            }
        };

        function createTextSprite(text, color, scale = 1.5) {
            const canvas = document.createElement('canvas');
            canvas.width = 128; 
            canvas.height = 128;
            const ctx = canvas.getContext('2d');
            ctx.fillStyle = color;
            ctx.font = 'bold 70px sans-serif'; 
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText(text, 64, 64);
            const texture = new THREE.CanvasTexture(canvas);
            const spriteMat = new THREE.SpriteMaterial({ map: texture, depthTest: false });
            const sprite = new THREE.Sprite(spriteMat);
            sprite.scale.set(scale, scale, scale);
            return sprite;
        }

        function init() {
            const container = document.getElementById('canvas-container');
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0xf1f5f9);

            camera = new THREE.PerspectiveCamera(50, container.clientWidth / container.clientHeight, 0.1, 1000);
            camera.position.set(12, 10, 16);

            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(container.clientWidth, container.clientHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            container.appendChild(renderer.domElement);

            // Setup Controls with reduced sensitivity
            controls = new THREE.OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.dampingFactor = 0.05; 
            controls.rotateSpeed = 0.5;    
            controls.zoomSpeed = 0.7;      
            controls.panSpeed = 0.6;       

            scene.add(new THREE.AmbientLight(0xffffff, 0.7));
            const dirLight = new THREE.DirectionalLight(0xffffff, 0.6);
            dirLight.position.set(10, 20, 10);
            scene.add(dirLight);

            atomsGroup = new THREE.Group();
            vectorsGroup = new THREE.Group();
            gridGroup = new THREE.Group();
            axesGroup = new THREE.Group();
            neighborsGroup = new THREE.Group(); 
            
            scene.add(atomsGroup, vectorsGroup, gridGroup, axesGroup, neighborsGroup);

            // Setup Cartesian Axes (XYZ)
            const axisLength = 7;
            const helper = new THREE.AxesHelper(axisLength);
            axesGroup.add(helper);

            const xLabel = createTextSprite('X', '#ef4444'); xLabel.position.set(axisLength + 0.5, 0, 0); axesGroup.add(xLabel);
            const yLabel = createTextSprite('Y', '#22c55e'); yLabel.position.set(0, axisLength + 0.5, 0); axesGroup.add(yLabel);
            const zLabel = createTextSprite('Z', '#3b82f6'); zLabel.position.set(0, 0, axisLength + 0.5); axesGroup.add(zLabel);

            const dashMat = new THREE.LineDashedMaterial({ color: 0x9ca3af, dashSize: 0.2, gapSize: 0.2 });
            const addDashed = (p1, p2) => {
                const geom = new THREE.BufferGeometry().setFromPoints([p1, p2]);
                const line = new THREE.Line(geom, dashMat);
                line.computeLineDistances();
                axesGroup.add(line);
            };
            addDashed(new THREE.Vector3(0,0,0), new THREE.Vector3(-axisLength,0,0));
            addDashed(new THREE.Vector3(0,0,0), new THREE.Vector3(0,-axisLength,0));
            addDashed(new THREE.Vector3(0,0,0), new THREE.Vector3(0,0,-axisLength));

            updateSimulation();
            window.addEventListener('resize', onWindowResize);
            animate();
        }

        function onWindowResize() {
            const container = document.getElementById('canvas-container');
            camera.aspect = container.clientWidth / container.clientHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(container.clientWidth, container.clientHeight);
        }

        function toggleNeighbors() {
            isShowingNeighbors = !isShowingNeighbors;
            updateSimulation();
        }

        function toggleVectors() {
            isShowingVectors = !isShowingVectors;
            updateSimulation();
        }

        function updateSimulation() {
            const typeKey = document.getElementById('lattice-select').value;
            const extent = parseInt(document.getElementById('extent-slider').value);
            const atomRadius = parseFloat(document.getElementById('size-slider').value);
            const showAxes = document.getElementById('show-axes').checked;
            const showCells = document.getElementById('show-cells').checked;
            
            const lattice = LATTICES[typeKey];
            const vectors = lattice.getVectors(a);

            axesGroup.visible = showAxes;

            // Cleanup
            while(atomsGroup.children.length > 0) atomsGroup.remove(atomsGroup.children[0]);
            while(vectorsGroup.children.length > 0) vectorsGroup.remove(vectorsGroup.children[0]);
            while(gridGroup.children.length > 0) gridGroup.remove(gridGroup.children[0]);
            while(neighborsGroup.children.length > 0) neighborsGroup.remove(neighborsGroup.children[0]);

            const sphereGeometry = new THREE.SphereGeometry(atomRadius, 16, 16);
            
            // Define Materials for different Atom states
            const atomMat = new THREE.MeshPhongMaterial({ color: 0x1e40af, shininess: 80 });         // Blue (Default)
            const originMat = new THREE.MeshPhongMaterial({ color: 0xef4444, shininess: 100 });      // Red (Origin)
            const primaryCellMat = new THREE.MeshPhongMaterial({ color: 0x22c55e, shininess: 80 });  // Green (Primary Unit Cell)
            const neighborMat = new THREE.MeshPhongMaterial({ color: 0xf59e0b, shininess: 100 });    // Amber (Nearest Neighbors)
            const bondMat = new THREE.LineBasicMaterial({ color: 0xf59e0b, transparent: true, opacity: 0.8 }); 

            let atomCount = 0;
            const epsilon = 0.01; 

            // SYMMETRICAL CUBIC BOUNDING BOX LOGIC
            const searchRadius = extent * 3; 
            const boundMin = -extent * a - epsilon;
            const boundMax = extent * a + epsilon;

            for (let n1 = -searchRadius; n1 <= searchRadius; n1++) {
                for (let n2 = -searchRadius; n2 <= searchRadius; n2++) {
                    for (let n3 = -searchRadius; n3 <= searchRadius; n3++) {
                        const pos = new THREE.Vector3()
                            .addScaledVector(vectors[0], n1)
                            .addScaledVector(vectors[1], n2)
                            .addScaledVector(vectors[2], n3);

                        // CLIPPING: Discard atoms outside the perfect cubic grid bounds
                        if (pos.x < boundMin || pos.x > boundMax ||
                            pos.y < boundMin || pos.y > boundMax ||
                            pos.z < boundMin || pos.z > boundMax) {
                            continue;
                        }

                        // Status checks
                        const isOrigin = n1 === 0 && n2 === 0 && n3 === 0;
                        const distToOrigin = pos.length();
                        const isNeighbor = Math.abs(distToOrigin - lattice.nnDistance) < epsilon;
                        
                        // Check if this atom perfectly belongs to the FIRST conventional unit cell
                        const isInPrimaryCell = (
                            pos.x >= -epsilon && pos.x <= a + epsilon &&
                            pos.y >= -epsilon && pos.y <= a + epsilon &&
                            pos.z >= -epsilon && pos.z <= a + epsilon
                        );

                        // Hierarchy of Colors: Red (Origin) > Amber (Neighbors) > Green (Unit Cell) > Blue (Rest)
                        let currentMat = atomMat;
                        if (isOrigin) {
                            currentMat = originMat;
                        } else if (isNeighbor && isShowingNeighbors) {
                            currentMat = neighborMat; 
                            const bondGeom = new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(0,0,0), pos]);
                            const bondLine = new THREE.Line(bondGeom, bondMat);
                            neighborsGroup.add(bondLine);
                        } else if (isInPrimaryCell) {
                            currentMat = primaryCellMat;
                        }

                        const atom = new THREE.Mesh(sphereGeometry, currentMat);
                        atom.position.copy(pos);
                        atomsGroup.add(atom);
                        atomCount++;
                    }
                }
            }

            // Primitive Vectors (Cyan, Fuchsia, Red)
            if (isShowingVectors) {
                const vectorColorsHex = [0x06b6d4, 0xd946ef, 0xef4444]; 
                const vectorColorsStr = ['#06b6d4', '#d946ef', '#ef4444']; 
                const vectorLabelsText = ['a₁', 'a₂', 'a₃'];

                vectors.forEach((v, i) => {
                    const arrow = new THREE.ArrowHelper(v.clone().normalize(), new THREE.Vector3(0,0,0), v.length(), vectorColorsHex[i], 0.4, 0.2);
                    vectorsGroup.add(arrow);

                    const labelSprite = createTextSprite(vectorLabelsText[i], vectorColorsStr[i], 1.2);
                    labelSprite.position.copy(v).multiplyScalar(1.25);
                    vectorsGroup.add(labelSprite);
                });
            }

            // --- UNIT CELL GRIDS ---

            const darkGridMaterial = new THREE.LineBasicMaterial({ 
                color: 0x020617, 
                transparent: true, 
                opacity: 0.85,
                polygonOffset: true,
                polygonOffsetFactor: -1,
                polygonOffsetUnits: -1
            });

            if (isShowingNeighbors) {
                // Draw the 8 unit cells surrounding the origin (the grid housing all the neighbors)
                const nPoints = [];
                for (let i = -1; i <= 1; i++) {
                    const val1 = i * a;
                    for (let j = -1; j <= 1; j++) {
                        const val2 = j * a;
                        nPoints.push(new THREE.Vector3(-a, val1, val2), new THREE.Vector3(a, val1, val2));
                        nPoints.push(new THREE.Vector3(val1, -a, val2), new THREE.Vector3(val1, a, val2));
                        nPoints.push(new THREE.Vector3(val1, val2, -a), new THREE.Vector3(val1, val2, a));
                    }
                }
                const nGeom = new THREE.BufferGeometry().setFromPoints(nPoints);
                const nGrid = new THREE.LineSegments(nGeom, darkGridMaterial);
                gridGroup.add(nGrid);
            } else {
                // Draw ONLY the Primary Single Unit Cell
                const boxSize = a;
                const singleGeom = new THREE.BoxGeometry(boxSize, boxSize, boxSize);
                singleGeom.translate(boxSize / 2, boxSize / 2, boxSize / 2); // Corner at origin
                const singleEdges = new THREE.EdgesGeometry(singleGeom);
                const singleCellLine = new THREE.LineSegments(singleEdges, darkGridMaterial);
                gridGroup.add(singleCellLine);
            }

            // Extended Unit Cell Grid
            if (showCells) {
                const points = [];
                const min = -extent * a;
                const max = extent * a;
                
                for (let i = -extent; i <= extent; i++) {
                    const val1 = i * a;
                    for (let j = -extent; j <= extent; j++) {
                        const val2 = j * a;
                        points.push(new THREE.Vector3(min, val1, val2), new THREE.Vector3(max, val1, val2));
                        points.push(new THREE.Vector3(val1, min, val2), new THREE.Vector3(val1, max, val2));
                        points.push(new THREE.Vector3(val1, val2, min), new THREE.Vector3(val1, val2, max));
                    }
                }
                const gridGeom = new THREE.BufferGeometry().setFromPoints(points);
                const gridLines = new THREE.LineSegments(gridGeom, new THREE.LineBasicMaterial({ 
                    color: 0x94a3b8, 
                    transparent: true, 
                    opacity: 0.3 
                }));
                gridGroup.add(gridLines);
            }

            // --- UPDATE UI ELEMENTS ---
            document.getElementById('stat-type').innerText = typeKey;
            document.getElementById('stat-atoms').innerText = atomCount;
            document.getElementById('extent-value').innerText = extent;
            document.getElementById('size-value').innerText = atomRadius.toFixed(2);
            
            // Handle Coordination Number Card Visuals
            const cnCard = document.getElementById('cn-card');
            const cnText = document.getElementById('stat-cn');
            if (isShowingNeighbors) {
                cnText.innerText = lattice.cn;
                cnCard.classList.replace('bg-amber-50/95', 'bg-amber-100');
            } else {
                cnText.innerText = "?";
                cnCard.classList.replace('bg-amber-100', 'bg-amber-50/95');
            }

            // Handle Basis Vector Card Visuals
            const vectorCard = document.getElementById('vector-card');
            const vectorText = document.getElementById('stat-basis');
            if (isShowingVectors) {
                vectorText.innerText = "3";
                vectorCard.classList.add('border-2', 'border-slate-300', 'bg-slate-100');
                vectorCard.classList.remove('border', 'border-gray-100', 'bg-white/95');
                vectorText.classList.replace('text-gray-400', 'text-slate-700');
            } else {
                vectorText.innerText = "OFF";
                vectorCard.classList.remove('border-2', 'border-slate-300', 'bg-slate-100');
                vectorCard.classList.add('border', 'border-gray-100', 'bg-white/95');
                vectorText.classList.replace('text-slate-700', 'text-gray-400');
            }

            document.getElementById('vector-formula').innerHTML = lattice.formula.map((f, i) => {
                const textClasses = ['text-cyan-400', 'text-fuchsia-400', 'text-red-500'];
                return `<div class="bg-slate-800/50 p-1 px-2 rounded text-center ${textClasses[i]} font-bold">${f}</div>`;
            }).join('');
        }

        function animate() {
            requestAnimationFrame(animate);
            controls.update();
            renderer.render(scene, camera);
        }

        // --- LISTENERS ---
        document.getElementById('lattice-select').addEventListener('change', () => {
            if (isShowingNeighbors) toggleNeighbors(); 
            else updateSimulation();
        });

        document.getElementById('extent-slider').addEventListener('input', updateSimulation);
        document.getElementById('size-slider').addEventListener('input', updateSimulation);
        document.getElementById('show-axes').addEventListener('change', updateSimulation);
        document.getElementById('show-cells').addEventListener('change', updateSimulation);
        
        // Interactive Overlay Cards
        document.getElementById('cn-card').addEventListener('click', toggleNeighbors);
        document.getElementById('vector-card').addEventListener('click', toggleVectors);

        window.onload = init;
    </script>
</body>
</html>
